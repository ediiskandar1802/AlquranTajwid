      },
      {
        "number": 4,
        "text": "مَالِكِ يَوْمِ الدِّينِ",
        "translation": "Penguasa hari Pembalasan.",
        "tajweedRules": "Tajweed: Sukun dan Tasydid",
        "audioUrl": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/1.mp3"
      },
      {
